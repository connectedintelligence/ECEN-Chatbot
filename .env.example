# ── Qdrant ──────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ecen_docs

# ── Embeddings (OpenAI-compatible) ──────────────────
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ── TAMU LLM API ────────────────────────────────────
OPENAI_API_KEY=your-tamu-api-key
OPENAI_MODEL=protected.gpt-5
OPENAI_BASE_URL=https://chat-api.tamu.ai/openai

# ── Crawler ─────────────────────────────────────────
TARGET_URL=https://engineering.tamu.edu/electrical/index.html
CRAWL_DELAY_SECONDS=1                         # be polite to the server
MAX_PAGES=500

# ── Re-index schedule ───────────────────────────────
REINDEX_CRON=0 2 * * *                        # 2 AM daily

# ── Sentry (optional error monitoring) ──────────────
# Backend (FastAPI). Leave blank to disable Sentry entirely.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
# Frontend (Next.js). NEXT_PUBLIC_* is exposed to the browser (safe — DSN only).
NEXT_PUBLIC_SENTRY_DSN=
# Source map upload at build time (CI only): from sentry.io org/project + token
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
